{
  "name": "vweb-marketing-sites",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "vweb-management",
    "_sites/*"
  ],
  "scripts": {
    "dev:hub": "npm run dev --workspace=vweb-management",
